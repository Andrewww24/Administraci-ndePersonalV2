@page
@model AdministracionPersonal.Core.Pages.Oferentes.IndexModel
@{
    ViewData["Title"] = "Oferentes aptos";
}


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
<style>
    .crud-card {
        border: none;
        border-radius: 4px;
        box-shadow: 0 3px 10px rgba(0,0,0,.08);
    }

    .crud-card-header {
        background: white;
        border-bottom: 1px solid #e5e7eb;
        padding: 16px 20px;
    }

    .crud-card-title {
        font-size: 17px;
        font-weight: 600;
        color: #243b73;
        margin: 0;
    }

    .table thead {
        background: #343a40;
        color: white;
    }

    .table td,
    .table th {
        vertical-align: middle;
    }
</style>

<div class="crud-card card">
    <div class="crud-card-header d-flex justify-content-between align-items-center">
        <h4 class="crud-card-title">
            <i class="fas fa-users"></i>
            Oferentes Aptos @(string.IsNullOrWhiteSpace(Model.Codigo) ? "" : $"— Puesto {Model.Codigo}")
        </h4>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-warning" role="alert">
                @Model.ErrorMessage
            </div>
        }
        else if (!Model.Oferentes.Any())
        {
            <div class="alert alert-info" role="alert">
                No se encontraron oferentes aptos para este puesto.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Identificación</th>
                            <th>Nombre completo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.Oferentes)
                        {
                            <tr>
                                <td>@o.Identificacion</td>
                                <td>
                                    <a asp-page="/Oferentes/Detalle" asp-route-identificacion="@o.Identificacion" asp-route-idPuesto="@Model.IdPuesto">
                                        @o.NombreCompleto
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
<a asp-page="/Puestos/Index" class="btn btn-secondary mt-3">Regresar</a>
