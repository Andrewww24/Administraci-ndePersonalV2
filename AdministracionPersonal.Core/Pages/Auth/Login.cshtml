@page "/login"
@model AdministracionPersonal.Core.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Ingreso al sistema";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
            :root {
                --sm-azul: #0d6efd;
                --sm-azul-claro: #3d8bfd;
                --sm-azul-oscuro: #0a58ca;
                --sm-campo: #eef2f8;
                --sm-borde: #e3e2dd;
                --sm-fondo: #f5f4f1;
            }

            body {
                min-height: 100vh;
                background-color: var(--sm-fondo);
                color: #22262b;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem 1rem;
            }

            .tarjeta {
                width: 100%;
                max-width: 380px;
                background-color: #fff;
                border: 1px solid var(--sm-borde);
                border-radius: 8px;
                overflow: hidden;
            }

            .tarjeta-header {
                background-color: var(--sm-azul);
                color: #fff;
                text-align: center;
                padding: 1.5rem 1.25rem;
            }

                .tarjeta-header h1 {
                    font-size: 1.25rem;
                    font-weight: 700;
                    margin: 0;
                }

                .tarjeta-header p {
                    font-size: .85rem;
                    margin: .25rem 0 0;
                    opacity: .9;
                }

            .tarjeta-body {
                padding: 1.5rem 1.25rem;
            }

            .form-label {
                font-size: .875rem;
                font-weight: 400;
                color: #22262b;
                margin-bottom: .35rem;
            }

            .form-control {
                background-color: var(--sm-campo);
                border: 1px solid transparent;
                border-radius: 5px;
                padding: .55rem .75rem;
                font-size: .95rem;
            }

                .form-control:focus {
                    background-color: var(--sm-campo);
                    border-color: var(--sm-azul-claro);
                    box-shadow: 0 0 0 3px rgba(13, 110, 253, .15);
                }

                /* Evita que el autocompletado de Chrome cambie el color del campo. */
                .form-control:-webkit-autofill,
                .form-control:-webkit-autofill:focus {
                    -webkit-text-fill-color: #22262b;
                    -webkit-box-shadow: 0 0 0 1000px var(--sm-campo) inset;
                }

            .btn-institucional {
                background-color: var(--sm-azul);
                border: 1px solid var(--sm-azul);
                color: #fff;
                border-radius: 5px;
                padding: .6rem;
                font-size: 1rem;
                font-weight: 500;
            }

                .btn-institucional:hover {
                    background-color: var(--sm-azul-claro);
                    color: #fff;
                }

                .btn-institucional:active {
                    background-color: var(--sm-azul-oscuro);
                    color: #fff;
                }

                .btn-institucional:focus-visible {
                    outline: none;
                    box-shadow: 0 0 0 3px rgba(13, 110, 253, .3);
                }

            .alert-institucional {
                background-color: #fdf2f0;
                border: 1px solid #f2d4cf;
                border-left: 3px solid #c0392b;
                color: #8a2b22;
                border-radius: 5px;
                font-size: .85rem;
                padding: .6rem .75rem;
            }
    </style>
</head>
<body>
    <div class="tarjeta">

        <div class="tarjeta-header">
            <h1>Administración de Personal</h1>
            <p>Servicios Médicos S.A.</p>
        </div>

        <div class="tarjeta-body">

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert-institucional mb-3" role="alert">@Model.ErrorMessage</div>
            }

            <form method="post" novalidate>
                <div class="mb-3">
                    <label for="Usuario" class="form-label">Usuario</label>
                    <input type="text" class="form-control" id="Usuario" name="Usuario"
                           value="@Model.Usuario" autocomplete="username" autofocus />
                </div>

                <div class="mb-4">
                    <label for="Password" class="form-label">Contraseña</label>
                    <input type="password" class="form-control" id="Password" name="Password"
                           autocomplete="current-password" />
                </div>

                <button type="submit" class="btn btn-institucional w-100">Aceptar</button>
            </form>

        </div>
    </div>
</body>
</html>
